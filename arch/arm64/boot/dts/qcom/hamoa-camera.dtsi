		clock-rates = <480000000 0 400000000 0>;
		operating-points-v2 = <&csiphy1_opp_table>;
		cell-index = <1>;
		status = "okay";

		csiphy1_opp_table: opp-table {
			compatible = "operating-points-v2";

			opp-400000000 {
				opp-hz = /bits/ 64 <400000000>;
				required-opps = <&rpmhpd_opp_nom>;
			};
		};
	};

	cam_csiphy2: qcom,csiphy2@ace8000 {
		compatible = "qcom,csiphy-v2.1.2", "qcom,csiphy";
		reg = <0x0 0xace8000 0x0 0x2000>;
		reg-names = "csiphy";
		reg-cam-base = <0xe8000>;
		interrupts = <GIC_SPI 479 IRQ_TYPE_EDGE_RISING>;
		interrupt-names = "CSIPHY2";
		power-domains = <&camcc CAM_CC_TITAN_TOP_GDSC>;
		regulator-names = "csi-vdd-1p2", "csi-vdd-0p9";
		csi-vdd-1p2-supply = <&vreg_l1c_1p2>;
