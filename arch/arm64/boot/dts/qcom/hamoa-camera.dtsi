		reg-cam-base = <0xf7000 0x13000>;
		power-domains = <&camcc CAM_CC_TITAN_TOP_GDSC>;
		interrupts = <GIC_SPI 416 IRQ_TYPE_EDGE_RISING>;
		interrupt-names = "tpg1";
