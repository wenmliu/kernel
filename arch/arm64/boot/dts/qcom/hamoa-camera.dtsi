		clock-cntl-level = "nominal";
		clock-rates = <480000000 0 400000000 0>;
		operating-points-v2 = <&csiphy2_opp_table>;
		cell-index = <2>;
		status = "okay";

		csiphy2_opp_table: opp-table {
